    "id": "TC_DOC_VALID_001",
    "description": "All mandatory fields filled — document should save successfully",
    "input": {
      "documentName": "Test Document Valid",
      "supplierDocId": "DOC-CERT-001",
      "remarks": "Automated test — valid data"
    },
    "expectError": false
  },
  {
    "id": "TC_DOC_EMPTY_001",

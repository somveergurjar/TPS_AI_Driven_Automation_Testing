    "errorFields": ["documentName", "documentType", "supplier"]
  },
  {
    "id": "TC_DOC_EMPTY_NAME",
    "description": "Document Name blank — only name error expected",
    "input": { "documentName": "" },
    "expectError": true,
    "errorFields": ["documentName"]
  },
  {
    "id": "TC_DOC_SPACES_NAME",
    "description": "Document Name contains only spaces — treated as empty",
    "input": { "documentName": "   " },
    "expectError": true,
    "errorFields": ["documentName"]
  },
  {
    "id": "TC_DOC_SPECIAL_CHARS",
    "description": "Special characters in Document Name — should be accepted",
    "input": { "documentName": "Doc !@#$%^&*()_+-=" },
    "expectError": false
  }

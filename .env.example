# ─── Application ───────────────────────────────────────────────────────────────
BASE_URL=https://dev.liveaccess.ai
LOGIN_URL=https://dev.liveaccess.ai/login

# ─── Credentials ───────────────────────────────────────────────────────────────
USER_EMAIL=your-email@example.com
USER_PASSWORD=your-password

# ─── Execution ─────────────────────────────────────────────────────────────────
HEADLESS=true
BROWSER=chromium
WORKERS=4
RETRIES=2

# ─── Timeouts (ms) ─────────────────────────────────────────────────────────────
TIMEOUT_NAVIGATION=30000
TIMEOUT_ELEMENT=15000
TIMEOUT_ACTION=10000

# ─── Reporting ─────────────────────────────────────────────────────────────────
ALLURE_RESULTS_DIR=allure-results
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=retain-on-failure
